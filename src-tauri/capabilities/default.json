{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for all app windows (main, main1, main2, …)",
  "windows": ["main*"],
  "permissions": [
    "core:default",
    "core:window:allow-destroy",
    "core:webview:allow-set-webview-zoom",
    "opener:default",
    "dialog:default"
  ]
}
