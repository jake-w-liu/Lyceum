{
  "name": "lyceum",
  "private": true,
  "version": "0.5.21",
  "type": "module",
  "description": "A lightweight, VS Code-inspired research IDE built with Tauri.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jake-w-liu/Lyceum.git"
  },
  "homepage": "https://github.com/jake-w-liu/Lyceum#readme",
  "bugs": {
    "url": "https://github.com/jake-w-liu/Lyceum/issues"
  },
  "engines": {
    "node": ">=20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "check": "npm run typecheck && npm test && npm run build && npm run check:bundle",
    "check:bundle": "node scripts/check-bundle-size.mjs",
    "audit": "npm audit --audit-level=moderate",
    "preview": "vite preview",
    "tauri": "node scripts/run-tauri.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "markdown-it": "^14.1.0",
    "monaco-editor": "^0.52.2",
    "pdfjs-dist": "^4.8.69",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/markdown-it": "^14.1.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^26.0.0",
    "typescript": "~5.8.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
